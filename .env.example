# Copy to .env for local development. Do NOT commit a real .env.
NODE_ENV=development

# Session signing secret (generate a long random string for production).
SESSION_SECRET=change-me-to-a-long-random-string

# Postgres connection string. On Railway this is injected automatically when a
# Postgres database is attached. Leave unset locally to run without a DB.
# DATABASE_URL=postgresql://user:pass@localhost:5432/ucs

# Port (Railway sets this automatically).
# PORT=3000
